/** An outpoint - a combination of a transaction hash and an index n into its vout */
class COutPoint
{
public:
    uint256 hash;
    uint32_t n;

    static constexpr uint32_t NULL_INDEX = std::numeric_limits<uint32_t>::max();

    COutPoint(): n(NULL_INDEX) { }
    COutPoint(const uint256& hashIn, uint32_t nIn): hash(hashIn), n(nIn) { }

    SERIALIZE_METHODS(COutPoint, obj) { READWRITE(obj.hash, obj.n); }

    void SetNull();
    bool IsNull() const;
    friend bool operator<(const COutPoint& a, const COutPoint& b);
    friend bool operator==(const COutPoint& a, const COutPoint& b);
    friend bool operator!=(const COutPoint& a, const COutPoint& b);
    std::string ToString() const;
};

/** An input of a transaction.  It contains the CTransaction that it refers to, which must have been previously unspent.
 *
 * Bitcoin transactions currently use the following fields:
 *
 * 1. COutPoint prevout
 * 2. CScript scriptSig
 * 3. uint32_t nSequence
 *
 */
class CTxIn
{
public:
    COutPoint prevout;
    CScript scriptSig;
    uint32_t nSequence;

    /* Setting nSequence to this value for every input in a transaction disables nLockTime. */
    static constexpr uint32_t SEQUENCE_FINAL = 0xffffffff;

    /* Below flags apply in the context of BIP 68*/
    /* If this flag set, CTxIn::nSequence is NOT interpreted as a relative lock-time. */
    static constexpr uint32_t SEQUENCE_LOCKTIME_DISABLE_FLAG = (1U << 31);

    /* If CTxIn::nSequence encodes a relative lock-time and this flag is set, the relative lock-time has units of blocks. */
    static constexpr uint32_t SEQUENCE_LOCKTIME_TYPE_FLAG = (1U << 22);

    /* If CTxIn::nSequence encodes a relative lock-time and this flag is set, the relative lock-time has units of 512-second intervals. */
    static constexpr uint32_t SEQUENCE_LOCKTIME_GRANULARITY_MASK = 0x3FFFC0; // This bitmask excludes the locktime disabled flag and the locktime type flag.

    CTxIn() : nSequence(SEQUENCE_FINAL) { }

    explicit CTxIn(COutPoint prevoutIn, CScript scriptSigIn=CScript(), uint32_t nSequenceIn=SEQUENCE_FINAL);
    CTxIn(uint256 hashPrevTx, uint32_t nOut, CScript scriptSigIn=CScript(), uint32_t nSequenceIn=SEQUENCE_FINAL);

    SERIALIZE_METHODS(CTxIn, obj) { READWRITE(obj.prevout, obj.scriptSig, obj.nSequence); }

    friend bool operator==(const CTxIn& a, const CTxIn& b);
    friend bool operator!=(const CTxIn& a, const CTxIn& b);
    std::string ToString() const;
};

/** An output of a transaction.  It contains the amount and script that it is sending to. */
class CTxOut
{
public:
    CAmount nValue;
    CScript scriptPubKey;

    CTxOut() : nValue(-1) { }
    CTxOut(const CAmount& nValueIn, CScript scriptPubKeyIn);

    SERIALIZE_METHODS(CTxOut, obj) { READWRITE(obj.nValue, obj.scriptPubKey); }

    friend bool operator==(const CTxOut& a, const CTxOut& b);
    friend bool operator!=(const CTxOut& a, const CTxOut& b);
    std::string ToString() const;
};

struct CMutableTransaction;

/**
 * Basic transaction class.
 *
 * A transaction can be either a 'regular' transaction or a 'coinbase' transaction.
 * A regular transaction is a transaction which is not a coinbase transaction.
 *
 * The fields of a CTransaction are as follows:
 * - nVersion       : Transaction version number.
 * - vin            : A list of inputs.
 * - vout           : A list of outputs.
 * - nLockTime      : A timestamp or block number specifying at what time or block height this transaction is valid.
 * - nExpiryHeight  : NEW: A block height after which this transaction becomes invalid.
 *
 * The serialization format is:
 * - int32_t nVersion
 * - std::vector<CTxIn> vin
 * - std::vector<CTxOut> vout
 * - uint32_t nLockTime
 * - uint32_t nExpiryHeight (NEW)
 */
class CTransaction
{
public:
    // TODO: make CTransaction::CURRENT_VERSION a class-static member in CTransaction
    static const int32_t CURRENT_VERSION=2; // Assuming we increment version for this fork

    // In a real fork, you might define a new version constant to signal
    // the presence of nExpiryHeight, e.g.:
    // static const int32_t EXPIRY_FEATURE_VERSION=3;
    // For simplicity, we'll assume it's part of CURRENT_VERSION for this example.

    int32_t nVersion;
    std::vector<CTxIn> vin;
    std::vector<CTxOut> vout;
    uint32_t nLockTime;
    uint32_t nExpiryHeight; // NEW FIELD: Transaction expiry block height

    // Internal helper for computing hashes
    template <typename Stream>
    void Serialize(Stream& s) const {
        s << nVersion;
        s << vin;
        s << vout;
        s << nLockTime;
        s << nExpiryHeight; // Serialize new field
    }

    template <typename Stream>
    void Unserialize(Stream& s) {
        s >> nVersion;
        s >> vin;
        s >> vout;
        s >> nLockTime;
        s >> nExpiryHeight; // Deserialize new field
    }

    // Default constructor
    CTransaction() : nVersion(CTransaction::CURRENT_VERSION), nLockTime(0), nExpiryHeight(0) {}

    // Constructor from CMutableTransaction
    explicit CTransaction(const CMutableTransaction& tx);
    explicit CTransaction(CMutableTransaction&& tx);

    uint256 GetHash() const;
    uint256 GetWitnessHash() const; // If witness is enabled
    bool IsCoinBase() const { return (vin.size() == 1 && vin[0].prevout.IsNull()); }

    // Helper to check if the transaction has an expiry set
    bool HasExpiry() const { return nExpiryHeight > 0; }

    // ... existing friend operators and other methods ...
    friend bool operator==(const CTransaction& a, const CTransaction& b);
    friend bool operator!=(const CTransaction& a, const CTransaction& b);
    std::string ToString() const;
};

/** A mutable transaction is one where the txid can be changed by updating a
 * field. The txid is the hash of the transaction.
 * The CMutableTransaction class is used for transactions in the process of
 * being constructed by the wallet or RPC clients.
 *
 * It is distinct from CTransaction, which is used for transactions that are
 * already finalized (e.g., received from the network, or stored in the
 * block chain).
 *
 * It has the same fields as CTransaction, but the fields are mutable.
 *
 * The fields of a CMutableTransaction are as follows:
 * - nVersion       : Transaction version number.
 * - vin            : A list of inputs.
 * - vout           : A list of outputs.
 * - nLockTime      : A timestamp or block number specifying at what time or block height this transaction is valid.
 * - nExpiryHeight  : NEW: A block height after which this transaction becomes invalid.
 */
struct CMutableTransaction
{
    int32_t nVersion;
    std::vector<CTxIn> vin;
    std::vector<CTxOut> vout;
    uint32_t nLockTime;
    uint32_t nExpiryHeight; // NEW FIELD: Mutable transaction expiry block height

    CMutableTransaction() : nVersion(CTransaction::CURRENT_VERSION), nLockTime(0), nExpiryHeight(0) {}
    explicit CMutableTransaction(const CTransaction& tx);

    // GetHash() will be calculated based on the current state of the mutable transaction
    uint256 GetHash() const;
    uint256 GetWitnessHash() const; // If witness is enabled
};

